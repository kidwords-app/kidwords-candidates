# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your_random_secret_here

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:3100/api/auth/callback/github  (local)
#               https://your-admin.vercel.app/api/auth/callback/github  (prod)
AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# Comma-separated list of GitHub usernames allowed in. Leave blank to allow any.
ALLOWED_GITHUB_LOGINS=

# ─── Provider selection ────────────────────────────────────────────────────────
# "mock"   → in-memory data from mock-data.ts (no token required, works offline)
# "github" → reads live data from the private candidates repo
PROVIDER=mock

# ─── GitHub provider (required when PROVIDER=github) ──────────────────────────
CANDIDATES_REPO_TOKEN=ghp_your_token_here
CANDIDATES_REPO_OWNER=kidwords-app
CANDIDATES_REPO_NAME=kidwords-candidates

# Required by the publish workflow (write access to the public app repo)
PUBLIC_REPO_TOKEN=ghp_your_public_token_here
PUBLIC_REPO_NAME=kidwords.github.io
