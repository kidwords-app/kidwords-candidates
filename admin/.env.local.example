# ─── Provider selection ────────────────────────────────────────────────────────
# "mock"   → in-memory data from mock-data.ts (no token required, works offline)
# "github" → reads live data from the private candidates repo
PROVIDER=mock

# ─── GitHub provider (required when PROVIDER=github) ──────────────────────────
CANDIDATES_REPO_TOKEN=ghp_your_token_here
CANDIDATES_REPO_OWNER=kidwords-app
CANDIDATES_REPO_NAME=kidwords-candidates

# Required by the publish workflow (write access to the public app repo)
PUBLIC_REPO_TOKEN=ghp_your_public_token_here
PUBLIC_REPO_NAME=kidwords.github.io
